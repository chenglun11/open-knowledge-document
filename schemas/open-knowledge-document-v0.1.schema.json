{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chenglun11/open-knowledge-document/schemas/open-knowledge-document-v0.1.schema.json",
  "title": "Open Knowledge Document 0.1 Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "source",
    "metadata",
    "document",
    "assets",
    "source_snapshot"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "id": { "type": "string", "minLength": 1 },
    "source": { "$ref": "#/$defs/source" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "permissions": { "$ref": "#/$defs/permissions" },
    "document": { "$ref": "#/$defs/node" },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" }
    },
    "source_snapshot": { "$ref": "#/$defs/sourceSnapshot" },
    "conversion": { "$ref": "#/$defs/conversion" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "document_id", "revision"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "document_id": { "type": "string", "minLength": 1 },
        "space_id": { "type": "string" },
        "revision": { "type": ["string", "integer"] },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title", "path", "status"],
      "properties": {
        "title": { "type": "string" },
        "path": { "type": "array", "items": { "type": "string" } },
        "status": {
          "enum": ["active", "archived", "deleted", "permission_denied", "error"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "visibility": { "enum": ["public", "organization", "restricted", "unknown"] },
        "allowed_users": { "type": "array", "items": { "type": "string" } },
        "allowed_groups": { "type": "array", "items": { "type": "string" } },
        "allowed_departments": { "type": "array", "items": { "type": "string" } },
        "source_acl_revision": { "type": "string" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "minLength": 1 },
        "attrs": { "type": "object", "additionalProperties": true },
        "text": { "type": "string" },
        "marks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string" },
              "attrs": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": false
          }
        },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        },
        "source_payload_ref": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "sha256", "media_type", "storage_ref"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "media_type": { "type": "string", "minLength": 1 },
        "filename": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "storage_ref": { "type": "string", "minLength": 1 },
        "source_asset_id": { "type": "string" }
      }
    },
    "sourceSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": ["format", "storage_ref", "sha256"],
      "properties": {
        "format": { "type": "string", "minLength": 1 },
        "storage_ref": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "conversion": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "converter": { "type": "string" },
        "converter_version": { "type": "string" },
        "converted_at": { "type": "string", "format": "date-time" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
